type = process
env-file = mullvad-env
capabilities = ^cap_net_admin,^cap_net_raw 
securebits = keep-caps-locked no-setuid-fixup no-setuid-fixup-locked
options: no-new-privs
command = /usr/bin/mullvad-daemon
log-type = buffer
restart = true

depends-on: udevd
depends-on: rootrw
depends-on: mullvad-pre
waits-for: udev-settle
